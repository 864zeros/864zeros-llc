{
  "name": "__MSG_appName__",
  "description": "__MSG_appDescription__",
  "version": "1.1.0",
  "manifest_version": 3,
  "author": "864zeros",
  "default_locale": "en",
  "action": {
    "default_title": "__MSG_openAction__"
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "sidePanel"
  ],
  "web_accessible_resources": [
    {
      "resources": ["audio/*.mp3"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "default-src 'self'; connect-src 'self' https:; media-src 'self' https:; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com;"
  }
}
