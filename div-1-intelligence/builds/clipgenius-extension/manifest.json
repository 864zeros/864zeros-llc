{
  "manifest_version": 3,
  "name": "ClipGenius - The Intelligent Web Clipper",
  "version": "1.0.0",
  "description": "Clip the web without the mess. The web clipper for modern note-takers that intelligently extracts content.",
  "default_locale": "en",
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "action": {
    "default_title": "Open ClipGenius Panel"
  },
  "options_page": "options/options.html"
}
